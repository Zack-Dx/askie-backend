generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}


model User {
  id           String       @id @default(uuid()) @unique
  name         String
  email        String       @unique
  googleId     String?      @default("")
  githubId     String?      @default("")
  picture      String
  role         Role         @default(user)
  password     String?      @default("")
  linkedinUrl  String?      @default("")  
  githubUrl    String?      @default("") 
  portfolioUrl String?      @default("")  
  twitterUrl   String?      @default("")  
  questionsAsked   Int      @default(0) 
  answersProvided  Int      @default(0) 
  location         String?  @default("")    
  about            String?  @default("")
  isPublic         Boolean  @default(true) 
  profession       String?  @default("")
  questions        Question[]  
  answers          Answer[]  
  notifications    Notification[] 
  votes            Vote[]   
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  isNewsSub        Boolean      @default(false)
  isPremium        Boolean      @default(false)
  premiumStartDate DateTime?    
  premiumEndDate   DateTime?    
  subscriptionPlan String?     
  payments Payment[] 
  chatSessions ChatSession[]
  freeAskieQuota   Int       @default(10) 
  premiumAskieQuota Int      @default(50)  
  lastAskieUsed   DateTime? 
}

model Question {
  id          String       @id @default(uuid()) @unique 
  title       String
  content     String
  context     String        @default("")
  user        User         @relation(fields: [userId], references: [id])
  userId      String     
  answers     Answer[]    
  tags        QuestionTag[] 
  votes       Vote[]      
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Answer {
  id          String       @id @default(uuid()) @unique 
  content     String
  user        User         @relation(fields: [userId], references: [id])
  userId      String      
  question    Question     @relation(fields: [questionId], references: [id])
  questionId  String     
  votes       Vote[]      
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  factScore   Int          @default(0) 
  Notification Notification[]
}

model Vote {
  id          String     @id @default(uuid()) @unique
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  question    Question?  @relation(fields: [questionId], references: [id])
  questionId  String?
  answer      Answer?    @relation(fields: [answerId], references: [id])
  answerId    String?
  value       Int        
  createdAt   DateTime   @default(now())

  @@unique([userId, questionId]) 
  @@unique([userId, answerId])   
}

model Notification {
  id        String     @id @default(uuid()) @unique
  content   String
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  href      String     @default("") 
  read      Boolean    @default(false) 
  createdAt DateTime   @default(now())
  answerId    String?
  answer      Answer?    @relation(fields: [answerId], references: [id])
}

model QuestionTag {
  id         String     @id @default(uuid()) @unique
  question   Question   @relation(fields: [questionId], references: [id])
  questionId String
  tag        Tag        @relation(fields: [tagId], references: [id])
  tagId      String
}

model Tag {
  id          String       @id @default(uuid()) @unique
  name        String       @unique
  questions   QuestionTag[]
}

enum Role {
  user
  admin
}

model Payment {
  id          String   @id @default(uuid()) @unique
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  orderId     String   @unique
  status      String
  paymentId   String?   @unique
  amount      Decimal  @db.Decimal()  
  currency    String
  receipt     String
  notes       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession{
  id          String   @id @default(uuid()) @unique
  sessionId   String
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  message     String
  role        String  
  createdAt   DateTime   @default(now())

   @@index([sessionId, createdAt])
}

